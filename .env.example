# Database
DATABASE_URL=postgresql://<db_user>:<db_password>@localhost:5433/<db_name>?schema=public

# JWT Configuration
JWT_SECRET=replace-with-a-random-32-plus-char-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=3001
NODE_ENV=development

# CORS - comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Security
BCRYPT_SALT_ROUNDS=12
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Mailer Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=2525
SMTP_USER=replace-with-smtp-user
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=noreply@example.com

# Redis Configuration (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Storage Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_BUCKET=cms-reports

# Encryption
ENCRYPTION_KEY=replace-with-a-random-32-plus-char-encryption-key
