generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// CORE AUTH & USERS (Phase 1)
// ==========================================

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Tenant {
  id        String       @id @default(uuid())
  name      String
  domain    String?      @unique
  status    TenantStatus @default(ACTIVE)
  settings  Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users            User[]
  roles            Role[]
  invitations      Invitation[]
  accessRules      AccessRule[]
  auditLogs        AuditLog[]
  consentTemplates ConsentTemplate[]
  applications     Application[]
  rightsRequests   RightsRequest[]
  grievances       Grievance[]
  cookieCategories CookieCategory[]
  cookieInventories CookieInventory[]
  scannedWebsites ScannedWebsite[]
  cookieBanners    CookieBanner[]
  cookieConsentLogs CookieConsentLog[]
  slaRules         SlaRule[]
  notificationRules NotificationRule[]
  escalationRules  EscalationRule[]
  notices          Notice[]
  noticeLanguages  NoticeLanguage[]
  noticeTypes      NoticeType[]
  integrations     Integration[]
  apiKeys          ApiKey[]
  encryptionConfig EncryptionConfig?
  logRetentionRules LogRetentionRule[]
  exportConfigs    ExportConfig[]
  aadhaarConfig    AadhaarConfig?
  workflowConfigs  WorkflowConfig[]
  generatedReports GeneratedReport[]
  consentWidgetConfigs ConsentWidgetConfig[]
}

enum UserStatus {
  ACTIVE
  DISABLED
  LOCKED
  PENDING
  SUSPENDED
}

enum AccountType {
  INTERNAL
  EXTERNAL
}

model User {
  id             String      @id @default(uuid())
  email          String      @unique
  emailHash      String?     @unique // For deterministic search
  password       String
  name           String
  phone          String?
  phoneHash      String?     // For deterministic search
  aadhaarNumber  String?     // Encrypted Aadhaar
  aadhaarHash    String?     // For deterministic search
  aadhaarVerified Boolean    @default(false)
  aadhaarVerifiedAt DateTime?
  status         UserStatus  @default(PENDING)
  accountType    AccountType @default(INTERNAL)
  department     String?
  mfaEnabled     Boolean     @default(false)
  mfaSecret      String?
  lastLogin      DateTime?
  validFrom      DateTime?
  validUntil     DateTime?
  riskScore      Int         @default(0)
  workflowAccess Json?
  apiAccess      Json?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles             UserRole[]
  sessions          Session[]
  sentInvitations   Invitation[]      @relation("InvitedBy")
  auditLogs         AuditLog[]
  createdTemplates  ConsentTemplate[]
  publishedVersions ConsentVersion[]
  generatedReports  GeneratedReport[]
}

enum RoleStatus {
  ACTIVE
  ARCHIVED
}

model Role {
  id           String     @id @default(uuid())
  name         String
  description  String?
  isSystemRole Boolean    @default(false)
  status       RoleStatus @default(ACTIVE)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  isTemporary Boolean   @default(false)
  clonedFrom  String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  users       UserRole[]
  permissions Permission[]
  invitations Invitation[]
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

enum ModuleName {
  DASHBOARD
  CONSENT_MANAGEMENT
  RIGHTS_MANAGEMENT
  GRIEVANCES
  COOKIES_MANAGEMENT
  NOTICES
  CONFIGURATIONS
  INTEGRATIONS
  SECURITY
  SETTINGS
  USER_SETUP
  REPORTS
  LOGS
}

model Permission {
  id     String @id @default(uuid())
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  module    ModuleName
  view      Boolean    @default(false)
  create    Boolean    @default(false)
  edit      Boolean    @default(false)
  approve   Boolean    @default(false)
  export    Boolean    @default(false)
  configure Boolean    @default(false)
  admin     Boolean    @default(false)

  @@unique([roleId, module])
}

enum SessionType {
  WEB
  MOBILE
  API
}

model Session {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  device           String?
  browser          String?
  ipAddress        String?
  location         String?
  loginTime        DateTime    @default(now())
  lastActivity     DateTime    @default(now())
  isCurrentSession Boolean     @default(true)
  sessionType      SessionType @default(WEB)
  refreshToken     String?     @unique

  @@index([userId, isCurrentSession])
  @@index([lastActivity])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  FAILED
}

model Invitation {
  id     String @id @default(uuid())
  email  String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  status    InvitationStatus @default(PENDING)
  invitedBy String
  inviter   User             @relation("InvitedBy", fields: [invitedBy], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  invitedAt  DateTime  @default(now())
  expiresAt  DateTime
  acceptedAt DateTime?
}

enum AccessRuleType {
  IP
  GEO
  TIME
  DEVICE
  CUSTOM
  RISK
}

enum AccessRuleStatus {
  ACTIVE
  INACTIVE
}

model AccessRule {
  id          String           @id @default(uuid())
  name        String
  type        AccessRuleType
  status      AccessRuleStatus @default(ACTIVE)
  description String?
  conditions  Json
  priority    Int              @default(0)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AuditCategory {
  PROFILE
  ROLE
  STATUS
  SESSION
  SECURITY
  TENANT
  WORKFLOW
  API
  BRANDING
  APPLICATION
}

model AuditLog {
  id     String  @id @default(uuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action    String
  category  AuditCategory
  details   Json?
  ipAddress String?
  severity  AuditSeverity @default(INFO)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())

  @@index([tenantId, category])
  @@index([createdAt])
  @@index([userId])
}

// ==========================================
// Phase 2: CONSENT MODULE
// ==========================================

enum TemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ConsentType {
  EXPLICIT
  IMPLICIT
  OPTIONAL
  MANDATORY
  GRANULAR
  PARENTAL
}

enum Regulation {
  DPDP
  GDPR
  TAPA
  PDPL
  CUSTOM
  CCPA
  LGPD
  PIPL
}

enum TargetUserCategory {
  CUSTOMER
  EMPLOYEE
  VENDOR
  MINOR
  GUARDIAN
}

enum ConsentGivenBy {
  SELF
  GUARDIAN
  REPRESENTATIVE
}

enum ConsentMechanism {
  CHECKBOX
  TOGGLE
  SIGNATURE
  CLICK_TO_CONFIRM
  AUDIO_VIDEO
}

enum PurposeNecessity {
  ESSENTIAL
  NON_ESSENTIAL
}

enum DataCategory {
  IDENTITY
  CONTACT
  FINANCIAL
  HEALTH
  BIOMETRIC
  BEHAVIORAL
  LOCATION
  CUSTOM
}

enum DataSource {
  DIRECT
  THIRD_PARTY
}

enum ThirdPartyRole {
  DATA_PROCESSOR
  JOINT_CONTROLLER
  SUB_PROCESSOR
}

model Purpose {
  id                  String           @id @default(uuid())
  name                String
  description         String?
  isPrimary           Boolean          @default(false)
  necessity           PurposeNecessity
  automatedProcessing Boolean          @default(false)
  profilingUsage      Boolean          @default(false)

  templateId String
  template   ConsentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DataCategoryConfig {
  id          String       @id @default(uuid())
  category    DataCategory
  label       String
  mandatory   Boolean      @default(true)
  source      DataSource   @default(DIRECT)
  description String?
  country     String?

  templateId String
  template   ConsentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ThirdParty {
  id                  String         @id @default(uuid())
  name                String
  role                ThirdPartyRole
  purpose             String
  country             String
  crossBorderTransfer Boolean        @default(false)

  templateId String
  template   ConsentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubProcessor {
  id                 String  @id @default(uuid())
  name               String
  purpose            String
  country            String
  changeNotification String?

  templateId String
  template   ConsentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DataRetention {
  id                          String  @id @default(uuid())
  period                      String
  justification               String
  autoDelete                  Boolean @default(false)
  postWithdrawalRules         String?
  expireConsentOnRetentionEnd Boolean @default(false)

  templateId String          @unique
  template   ConsentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SecurityMeasures {
  id                  String   @id @default(uuid())
  encryptionAtRest    Boolean  @default(false)
  encryptionInTransit Boolean  @default(false)
  accessControls      String?
  monitoringLogging   String?
  incidentResponse    String?
  certifications      String[]
  additionalMeasures  String[]

  templateId String          @unique
  template   ConsentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WithdrawalInfo {
  id                 String  @id @default(uuid())
  method             String
  effect             String
  rightsLink         String?
  processingTimeline String?

  templateId String          @unique
  template   ConsentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConsentTemplate {
  id                 String               @id @default(uuid())
  title              String
  description        String?
  type               ConsentType          @default(EXPLICIT)
  regulations        Regulation[]
  status             TemplateStatus       @default(DRAFT)
  wizardFields       Json? // For storing dynamic form fields/questions
  validityStart      DateTime?
  validityEnd        DateTime?
  noExpiry           Boolean              @default(true)
  targetUserCategory TargetUserCategory[]
  ageThreshold       Int                  @default(18)
  consentGivenBy     ConsentGivenBy       @default(SELF)
  mechanism          ConsentMechanism     @default(CHECKBOX)
  separateConsents   Boolean              @default(false)
  withdrawVisible    Boolean              @default(true)
  dataSharing        Boolean              @default(false)
  privacyNoticeRef   String?
  auditTrailEnabled  Boolean              @default(true)
  defaultLanguage    String               @default("en")
  supportedLanguages String[]

  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id])
  createdBy String
  creator   User   @relation(fields: [createdBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purposes       Purpose[]
  dataCategories DataCategoryConfig[]
  thirdParties   ThirdParty[]
  subProcessors  SubProcessor[]
  retention      DataRetention?
  security       SecurityMeasures?
  withdrawal     WithdrawalInfo?

  versions          ConsentVersion[]
  usageRecords      ConsentUsageRecord[]
  applicationUsages ApplicationUsage[]
  widgetConfigs     ConsentWidgetConfig[]
}

enum ConsentVersionStatus {
  ACTIVE
  ARCHIVED
  LOCKED
}

model ConsentVersion {
  id            String               @id @default(uuid())
  versionNumber Int
  content       String // The actual text/HTML of the agreement
  status        ConsentVersionStatus @default(ACTIVE)

  // Change tracking (from flow spec section 3.6)
  changeSummary    String?
  changedFields    String[] // List of changed field names
  changeReason     String?
  approvedBy       String?
  approvalTimestamp DateTime?
  effectiveFrom    DateTime?
  effectiveTo      DateTime?
  usersImpacted    Int       @default(0)
  reconsentTriggered Boolean  @default(false)

  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  templateId  String
  template    ConsentTemplate @relation(fields: [templateId], references: [id])
  publishedBy String
  publisher   User            @relation(fields: [publishedBy], references: [id])

  deployments ConsentDeployment[]
  records     ConsentRecord[]

  @@unique([templateId, versionNumber])
}

model Application {
  id          String  @id @default(uuid())
  name        String
  description String?
  apiKey      String  @unique // For integrating APIs

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deployments   ConsentDeployment[]
  records       ConsentRecord[]
  widgetConfigs ConsentWidgetConfig[]
}

// ==========================================
// CONSENT DEPLOYMENT (Enriched per flow spec 3.3/3.4)
// ==========================================

enum DeploymentMode {
  MANUAL
  SCHEDULED
}

enum DeploymentStatus {
  DEPLOYED
  PENDING
  FAILED
  ROLLED_BACK
}

model ConsentDeployment {
  id            String           @id @default(uuid())
  versionId     String
  version       ConsentVersion   @relation(fields: [versionId], references: [id])
  applicationId String
  application   Application      @relation(fields: [applicationId], references: [id])

  deploymentMode      DeploymentMode   @default(MANUAL)
  status              DeploymentStatus @default(PENDING)
  activationDate      DateTime?
  region              String?   // e.g., "India", "EU", "India, UAE"
  platform            String[]  // e.g., ["Web", "Mobile", "API"]
  userSegment         String?   // e.g., "All Users", "Enterprise"
  deployedBy          String?   // FK → User (who deployed)
  affectedUsers       Int       @default(0)
  approvalRequired    Boolean   @default(false)
  approvedBy          String?
  rollbackAllowed     Boolean   @default(true)
  rollbackConditions  String?
  lockedAfterActivation Boolean @default(false)

  isActive   Boolean  @default(true)
  deployedAt DateTime @default(now())

  logs DeploymentLog[]

  @@unique([versionId, applicationId])
}

// ==========================================
// DEPLOYMENT LOG (flow spec 3.5)
// ==========================================

enum DeploymentLogStatus {
  SUCCESS
  FAILURE
}

model DeploymentLog {
  id           String              @id @default(uuid())
  deploymentId String
  deployment   ConsentDeployment   @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  action      String    // e.g., "Deployed", "Rolled back", "Approved"
  timestamp   DateTime  @default(now())
  performedBy String    // User who performed the action
  details     String?
  status      DeploymentLogStatus @default(SUCCESS)
}

// ==========================================
// CONSENT USAGE & CROSS-APP (flow spec 3.7, 3.9)
// ==========================================

enum ConsentUsageStatus {
  ACTIVE
  WITHDRAWN
  EXPIRED
}

model ConsentUsageRecord {
  id              String             @id @default(uuid())
  userIdentifier  String             // Masked user ID (e.g., USR-****-7842)
  ipAddress       String?
  templateId      String
  template        ConsentTemplate    @relation(fields: [templateId], references: [id])
  version         String
  purposeMapped   String
  systemApp       String             // System where consent was captured
  consentDateTime DateTime           @default(now())
  consentStatus   ConsentUsageStatus @default(ACTIVE)
  lastValidation  DateTime?
}

enum ApplicationUsageStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  PENDING
}

enum ApplicationUsageType {
  CRM
  HRMS
  WEBSITE
  API
  MOBILE
  ERP
  INTERNAL
}

model ApplicationUsage {
  id               String                 @id @default(uuid())
  templateId       String
  template         ConsentTemplate        @relation(fields: [templateId], references: [id])
  templateVersion  String
  applicationName  String
  applicationType  ApplicationUsageType
  systemOwner      String?
  purposeUsed      String
  lastValidation   DateTime?
  status           ApplicationUsageStatus @default(ACTIVE)
  usersConsented   Int                    @default(0)
  violations       Int                    @default(0)
}

// ==========================================
// CONSENT RECORDS (End-user level)
// ==========================================

enum ConsentStatus {
  GRANTED
  REVOKED
}

model ConsentRecord {
  id            String         @id @default(uuid())
  versionId     String
  version       ConsentVersion @relation(fields: [versionId], references: [id])
  applicationId String
  application   Application    @relation(fields: [applicationId], references: [id])

  userId       String? // If the end-user is known/logged in
  endUserEmail String? // If capturing consent for an anonymous user via email
  endUserPhone String?
  endUserIp    String? // Traceability
  
  // Blind Indexes for PII Search (DSAR fulfillment)
  endUserEmailHash String?
  endUserPhoneHash String?

  status    ConsentStatus @default(GRANTED)
  grantedAt DateTime      @default(now())
  revokedAt DateTime?

  metadata Json? // E.g., device info, raw wizard answers

  @@index([status])
  @@index([applicationId, status])
  @@index([grantedAt])
  @@index([endUserEmailHash])
  @@index([endUserPhoneHash])
}

// ==========================================
// Phase 3: RIGHTS MANAGEMENT MODULE
// ==========================================

enum RightsRequestType {
  FILE_COMPLAINT
  WITHDRAW_CONSENT
  ACCESS
  CORRECTION
  ERASURE
  GRIEVANCE_REDRESSAL
  NOMINATE
}

enum RightsRequestStatus {
  RECEIVED
  IDENTITY_VERIFIED
  ACKNOWLEDGED
  IN_REVIEW
  ACTION_TAKEN
  RESPONSE_SENT
  CLOSED
  REJECTED
  ESCALATED
  ON_HOLD
}

enum RightsRequestPriority {
  LOW
  NORMAL
  URGENT
  CRITICAL
}

enum VerificationStatus {
  VER_PENDING
  VERIFIED
  VER_FAILED
  VER_EXPIRED
}

enum VerificationMethod {
  OTP
  EMAIL_VERIFY
  AADHAAR_EKYC
  DIGILOCKER
  KNOWLEDGE_BASED
  AUTHORIZED_REP
  MANUAL_VERIFY
}

enum SubmissionChannel {
  WEB
  API_CHANNEL
  EMAIL_CHANNEL
  PHONE
  IN_PERSON
}

enum WorkflowStepStatus {
  WF_PENDING
  WF_IN_PROGRESS
  WF_COMPLETED
  WF_SKIPPED
}

enum CaseNoteType {
  NOTE_INTERNAL
  NOTE_EXTERNAL
}

enum AttachmentCategory {
  IDENTITY_PROOF
  DATA_EXTRACT
  DELETION_CONFIRMATION
  COMMUNICATION
  ATT_OTHER
}

model RightsRequest {
  id         String @id @default(uuid())
  caseNumber String @unique // Business key: RR-2026-000001

  type       RightsRequestType
  regulation Regulation          // Reuses existing enum
  status     RightsRequestStatus @default(RECEIVED)
  priority   RightsRequestPriority @default(NORMAL)

  // Requester info
  requesterId  String
  requesterName String
  requesterEmail String
  requesterEmailHash String?   // For searching
  requesterPhone String?
  requesterPhoneHash String?   // For searching
  aadhaarNumber  String?     // Encrypted
  aadhaarHash    String?     // For searching

  // Authorization
  isAuthorizedRep      Boolean @default(false)
  authorizedRepDetails Json?   // {name, relationship, proofDocument}

  // Verification
  verificationStatus     VerificationStatus  @default(VER_PENDING)
  verificationMethod     VerificationMethod?
  reVerificationRequired Boolean @default(false)
  fraudFlag              Boolean @default(false)

  // Request details
  dataCategories      String[] // Personal, Financial, Health, etc.
  description         String
  relatedConsents     String[] // ConsentTemplate IDs
  relatedApplications String[] // App names

  // Submission
  submissionChannel SubmissionChannel @default(WEB)
  submittedAt       DateTime         @default(now())
  acknowledgedAt    DateTime?
  closedAt          DateTime?

  // SLA
  dueDate DateTime? // slaBreached & daysRemaining computed at query time
  
  // Alert Status
  nearBreachAlertSent Boolean @default(false)
  slaAlertSent        Boolean @default(false)

  // Assignment
  assignedTo   String? // FK → User (not enforced to allow external IDs)
  assignedTeam String?
  currentStep  String?

  // Tenant
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  workflowSteps WorkflowStep[]
  notes         CaseNote[]
  attachments   CaseAttachment[]
  evidenceItems EvidenceItem[]
  auditEntries  RightsAuditEntry[]

  @@index([tenantId, status])
  @@index([dueDate])
  @@index([assignedTo])
}

model WorkflowStep {
  id        String @id @default(uuid())
  requestId String
  request   RightsRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  name         String
  order        Int
  status       WorkflowStepStatus @default(WF_PENDING)
  assignedRole String?
  slaHours     Int?
  completedAt  DateTime?
  completedBy  String?
  notes        String?

  @@unique([requestId, order])
}

model CaseNote {
  id        String @id @default(uuid())
  requestId String
  request   RightsRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  type        CaseNoteType @default(NOTE_INTERNAL)
  content     String
  createdBy   String
  createdAt   DateTime     @default(now())
  attachments String[]     // URLs or file references
}

model CaseAttachment {
  id        String @id @default(uuid())
  requestId String
  request   RightsRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  fileName   String
  fileType   String
  fileSize   String
  category   AttachmentCategory @default(ATT_OTHER)
  uploadedBy String
  uploadedAt DateTime           @default(now())
  url        String
}

model EvidenceItem {
  id        String @id @default(uuid())
  requestId String
  request   RightsRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  caseNumber String // Denormalized for quick lookup
  fileName   String
  fileType   String
  category   String
  uploadedBy String
  uploadedAt DateTime @default(now())
  size       String
  verified   Boolean  @default(false)
}

model RightsAuditEntry {
  id        String @id @default(uuid())
  requestId String
  request   RightsRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  caseNumber        String
  action            String
  performedBy       String
  performedAt       DateTime      @default(now())
  details           String?
  systemApplication String?
  ipAddress         String?
  consentVersion    String?
  severity          AuditSeverity @default(INFO) // Reuses existing enum
}

// ==========================================
// GRIEVANCES MODULE
// ==========================================

enum GrievanceCategory {
  DATA_ACCESS
  CONSENT
  PRIVACY
  DATA_ERASURE
  DATA_PORTABILITY
  MINOR_CONSENT
  NOTICE
  SLA
}

enum GrievanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ESCALATED
}

enum GrievancePriority {
  GRV_LOW
  GRV_MEDIUM
  GRV_HIGH
  GRV_CRITICAL
}

model Grievance {
  id          String @id @default(uuid())
  caseNumber  String @unique // Business key: GRV-2026-0001

  subject     String
  description String?
  userId      String  // Requester/filer
  userName    String?
  userEmail   String?
  userEmailHash String? // For searching

  category    GrievanceCategory
  priority    GrievancePriority  @default(GRV_MEDIUM)
  status      GrievanceStatus    @default(OPEN)

  assignedTo  String?
  assignedTeam String?

  tenantId    String?
  tenant      Tenant? @relation(fields: [tenantId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Alert Status
  nearBreachAlertSent Boolean @default(false)
  slaAlertSent        Boolean @default(false)
  resolvedAt  DateTime?
  escalatedAt DateTime?

  comments GrievanceComment[]
}

model GrievanceComment {
  id          String @id @default(uuid())
  grievanceId String
  grievance   Grievance @relation(fields: [grievanceId], references: [id], onDelete: Cascade)

  content     String
  createdBy   String
  createdAt   DateTime @default(now())
}

// ==========================================
// COOKIES MANAGEMENT MODULE
// ==========================================

enum CookieCategoryType {
  NECESSARY
  ANALYTICS
  FUNCTIONAL
  ADVERTISING
  UNCATEGORIZED
}

model CookieCategory {
  id          String             @id @default(uuid())
  name        String
  category    CookieCategoryType
  description String?
  enabled     Boolean            @default(true)
  locked      Boolean            @default(false)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cookies CookieInventory[]
}

model CookieInventory {
  id          String         @id @default(uuid())
  name        String
  domain      String
  expiration  String?
  description String?

  categoryId String
  category   CookieCategory @relation(fields: [categoryId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  websiteId String?
  website   ScannedWebsite? @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ScanFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
}

enum ScanStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum ScanDepth {
  STANDARD
  DEEP
}

model ScannedWebsite {
  id              String        @id @default(uuid())
  name            String
  url             String
  frequency       ScanFrequency @default(MONTHLY)
  lastScan        DateTime?
  status          ScanStatus    @default(PENDING)
  depth           ScanDepth     @default(STANDARD)
  email           String?       // notification contact
  autoCategorize  Boolean       @default(false)
  scanBehindLogin Boolean       @default(false)
  loginUrl        String?
  loginUserField  String?       // CSS selector for username input
  loginPassField  String?       // CSS selector for password input
  loginUsername   String?
  loginPassword   String?

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  cookieBanners CookieBanner[]
  cookieConsentLogs CookieConsentLog[]
  cookies CookieInventory[]

  // Compliance & Scanning Intelligence
  complianceScore     Float?
  riskLevel           String?   // LOW, MEDIUM, HIGH
  complianceGrade     String?   // A, B, C, D, F
  pagesCrawled        Int?
  cookiesDetected     Int?
  thirdPartyScripts   Json?     // Array of detected third party scripts
  scanResults         Json?     // Detailed breakdown of the 10 indicators
  previousScore       Float?    
  nextScheduledScan   DateTime?
  changeDetected      Boolean   @default(false)

  // Identity & Contact
  pocName             String?
  pocEmail            String?
  organizationName    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BannerPosition {
  BOTTOM
  TOP
  CENTER
  CORNER
}

enum BannerStatus {
  DRAFT
  ACTIVE
}

model CookieBanner {
  id        String         @id @default(uuid())
  name      String
  theme     String         // e.g., CSS class or JSON config
  language  String         @default("en")
  position  BannerPosition @default(BOTTOM)
  status    BannerStatus   @default(DRAFT)
  
  heading     String?
  description String?
  themeColor  String? // Button background color
  
  // Advanced Styling
  textColor         String? @default("#111827")
  backgroundColor   String? @default("#ffffff")
  buttonTextColor   String? @default("#ffffff")
  borderRadius      Int?    @default(12)
  maxWidth          Int?    @default(1200)
  fontSize          Int?    @default(14)
  padding           Int?    @default(24)
  backdropBlur      Int?    @default(0)
  backdropOpacity   Int?    @default(50)

  websiteId String?
  website   ScannedWebsite? @relation(fields: [websiteId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ConsentLogStatus {
  ACCEPTED
  WITHDRAWN
  REJECTED
}

model CookieConsentLog {
  id         String           @id @default(uuid())
  userId     String?          // logged in user or anonymous ID
  date       DateTime         @default(now())
  region     String?
  language   String?          @default("en")
  categories String[]         // IDs of categories accepted
  status     ConsentLogStatus @default(ACCEPTED)
  ipAddress  String?

  websiteId String?
  website   ScannedWebsite? @relation(fields: [websiteId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// CONFIGURATION MODULE — Phase 1
// ==========================================

// --- SLA Rules ---

enum SLADurationUnit {
  HOURS
  DAYS
}

enum SLADayType {
  WORKING
  CALENDAR
}

enum SLAScope {
  RIGHTS
  GRIEVANCES
}

enum SLARuleStatus {
  SLA_ACTIVE
  SLA_INACTIVE
  SLA_ARCHIVED
}

model SlaRule {
  id              String          @id @default(uuid())
  name            String
  regulation      Regulation?     // Reuses existing enum
  rightType       RightsRequestType? // Only when scope = RIGHTS
  category        String?         // Grievance category or custom label
  priority        String?         // e.g., "LOW", "NORMAL", "URGENT", "CRITICAL"
  duration        Int
  durationUnit    SLADurationUnit @default(DAYS)
  dayType         SLADayType      @default(CALENDAR)
  scope           SLAScope        @default(RIGHTS)
  pauseConditions String[]
  autoCloseEnabled Boolean        @default(false)
  breachActions   String[]
  status          SLARuleStatus   @default(SLA_ACTIVE)
  version         Int             @default(1)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Notification Rules ---

enum NotificationChannel {
  EMAIL
  SMS
  IN_APP
  WEBHOOK
}

enum RecipientType {
  NOTIF_USER
  NOTIF_ROLE
  NOTIF_ADMIN
  NOTIF_EXTERNAL
}

enum NotificationFrequency {
  IMMEDIATE
  BATCHED
  SCHEDULED
}

enum ConfigRuleStatus {
  CFG_ACTIVE
  CFG_INACTIVE
}

model NotificationRule {
  id              String                @id @default(uuid())
  name            String
  triggerEvent    String                // e.g., "rights_request_created", "sla_breach", "grievance_escalated"
  channel         NotificationChannel   @default(EMAIL)
  recipientType   RecipientType         @default(NOTIF_ROLE)
  template        String?               // Template ID or inline template
  language        String                @default("en")
  frequency       NotificationFrequency @default(IMMEDIATE)
  retryEnabled    Boolean               @default(false)
  maxRetries      Int                   @default(3)
  status          ConfigRuleStatus      @default(CFG_ACTIVE)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Escalation Rules ---

enum EscalationTrigger {
  SLA_BREACH
  MANUAL_FLAG
  RISK_SCORE
  PRIORITY_CHANGE
}

enum EscalationLevel {
  L1
  L2
  L3
}

enum EscalationAction {
  NOTIFY
  REASSIGN
  LOCK_CASE
  ESCALATE_EXTERNAL
}

model EscalationRule {
  id                    String             @id @default(uuid())
  name                  String
  triggerCondition      EscalationTrigger  @default(SLA_BREACH)
  triggerThreshold      Int?               // e.g., hours past SLA, risk score threshold
  escalationLevel       EscalationLevel    @default(L1)
  recipientRole         String             // Role name to escalate to
  recipientUser         String?            // Specific user ID (optional)
  action                EscalationAction   @default(NOTIFY)
  maxLevels             Int                @default(3)
  autoCloseOnResolution Boolean            @default(true)
  status                ConfigRuleStatus   @default(CFG_ACTIVE)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// NOTICES MODULE — Phase 2
// ==========================================

enum NoticeStatus {
  NOTICE_ACTIVE
  NOTICE_DRAFT
  NOTICE_PENDING_REVIEW
  NOTICE_ARCHIVED
}

model Notice {
  id              String       @id @default(uuid())
  title           String
  content         String?      // Rich text / HTML content
  currentVersion  Int          @default(1)
  status          NoticeStatus @default(NOTICE_DRAFT)

  typeId String?
  type   NoticeType? @relation(fields: [typeId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enforceAcknowledgement Boolean @default(false)
  autoArchive            Boolean @default(true)
  auditLogging           Boolean @default(true)
  defaultLanguage        String  @default("en")

  versions        NoticeVersion[]
  acknowledgements NoticeAcknowledgement[]
}

model NoticeVersion {
  id       String @id @default(uuid())
  noticeId String
  notice   Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade)

  version  Int
  title    String
  content  String?  // Snapshot of content at this version
  changes  String?  // Summary of changes made
  author   String?  // User who created this version

  createdAt DateTime @default(now())

  @@unique([noticeId, version])
}

model NoticeLanguage {
  id         String  @id @default(uuid())
  code       String  // e.g., "en", "hi", "ar"
  name       String  // e.g., "English", "Hindi", "Arabic"
  isDefault  Boolean @default(false)
  completion Int     @default(0) // Percentage 0-100

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NoticeType {
  id          String  @id @default(uuid())
  name        String  // e.g., "Privacy Policy", "Terms of Service", "Cookie Policy"
  description String?
  required    Boolean @default(false)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notices Notice[]
}

model NoticeAcknowledgement {
  id       String @id @default(uuid())
  noticeId String
  notice   Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade)

  userId        String?  // Logged-in user ID
  userEmail     String?  // Anonymous user email
  acknowledgedAt DateTime @default(now())
  version       Int      // Which version was acknowledged
  ipAddress     String?
  userAgent     String?  // Browser/Device info
  viewDuration  Int?     // Time spent in seconds
  language      String?  // Language code (e.g., "en", "hi")
  visitId       String?  @unique // Unique ID for the visit session
}

// ==========================================
// INTEGRATIONS MODULE — Phase 4
// ==========================================

enum IntegrationType {
  CRM
  ANALYTICS
  CUSTOM
  ERP
  COMMUNICATION
  IDENTITY
  STORAGE
  GATEWAY
  CONNECTOR
}

enum IntegrationStatus {
  CONNECTED
  PENDING
  DISCONNECTED
  ERROR
}

model Integration {
  id         String            @id @default(uuid())
  name       String
  type       IntegrationType   @default(CUSTOM)
  status     IntegrationStatus @default(DISCONNECTED)
  icon       String?           // URL or icon identifier
  lastSync   DateTime?
  apiCalls   Int               @default(0)
  config     Json?             // Connection config (API keys, endpoints, etc.)
  errorMessage String?         // Last error message if status = ERROR

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  syncLogs  IntegrationSyncLog[]
}

model IntegrationSyncLog {
  id            String   @id @default(uuid())
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  syncType      String   // "manual" | "scheduled" | "webhook"
  status        String   // "success" | "failed" | "partial"
  recordsSynced Int      @default(0)
  errorDetails  String?
  startedAt     DateTime @default(now())
  completedAt   DateTime?
}

// ==========================================
// ADVANCED CONFIG MODULE — Phase 5
// ==========================================

model ApiKey {
  id        String    @id @default(uuid())
  name      String
  key       String    @unique
  scopes    String[]  // ["read:consent", "write:consent", etc.]
  expiresAt DateTime?
  lastUsed  DateTime?
  status    ConfigRuleStatus @default(CFG_ACTIVE)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EncryptionConfig {
  id               String  @id @default(uuid())
  algorithm        String  @default("AES-256-GCM")
  keyRotationDays  Int     @default(90)
  lastRotation     DateTime?
  status           ConfigRuleStatus @default(CFG_ACTIVE)
  provider         String  @default("KMS") // "KMS" | "Vault" | "Local"

  tenantId String? @unique // One config per tenant
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LogType {
  AUDIT
  CONSENT
  RIGHTS
  GRIEVANCE
  SECURITY
  SYSTEM
}

model LogRetentionRule {
  id              String   @id @default(uuid())
  logType         LogType
  retentionPeriod Int      @default(365)
  retentionUnit   String   @default("days") // "days" | "months" | "years"
  regulation      String?
  autoArchive     Boolean  @default(true)
  autoDelete      Boolean  @default(false)
  status          ConfigRuleStatus @default(CFG_ACTIVE)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExportConfig {
  id                  String   @id @default(uuid())
  name                String
  reportType          String   // "CONSENT" | "RIGHTS" | "COMPLIANCE" | "AUDIT"
  format              String   @default("csv") // "pdf" | "csv" | "json" | "xlsx"
  scheduleFrequency   String   @default("on-demand") // "daily" | "weekly" | "monthly" | "on-demand"
  scheduledTime       String?
  recipients          String[]
  dataMaskingEnabled  Boolean  @default(true)
  brandingEnabled     Boolean  @default(true)
  status              ConfigRuleStatus @default(CFG_ACTIVE)
  lastExecuted        DateTime?
  nextExecution       DateTime?

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AadhaarConfig {
  id                   String  @id @default(uuid())
  enabled              Boolean @default(false)
  environment          String  @default("sandbox") // "sandbox" | "production"
  verificationMode     String  @default("otp") // "otp" | "offline-xml" | "masked-only"
  usageScopes          String[]
  consentRequired      Boolean @default(true)
  consentText          String?
  consentRetentionDays Int     @default(30)
  autoPurgeEnabled     Boolean @default(true)
  autoPurgeDays        Int     @default(7)
  serviceProviderName  String?
  rateLimit            Int     @default(100)

  tenantId String? @unique
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkflowConfig {
  id          String   @id @default(uuid())
  name        String
  description String?
  type        String   // "RIGHTS" | "GRIEVANCE" | "CONSENT"
  steps       Json     // Array of workflow steps with roles/actions
  status      ConfigRuleStatus @default(CFG_ACTIVE)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// REPORTS MODULE
// ==========================================

enum ReportType {
  CONSENT
  RIGHTS
  COMPLIANCE
  AUDIT
  DSAR_EXPORT
}

enum ReportFormat {
  PDF
  CSV
  JSON
  XLSX
}

enum ReportStatus {
  RPT_PENDING
  RPT_PROCESSING
  RPT_COMPLETED
  RPT_FAILED
}

model GeneratedReport {
  id          String       @id @default(uuid())
  name        String
  reportType  ReportType
  format      ReportFormat @default(CSV)
  status      ReportStatus @default(RPT_PENDING)
  
  generatedBy String       // User ID
  user        User         @relation(fields: [generatedBy], references: [id])

  filePath    String?      // Path to the generated file
  fileSize    Int?         // Size in bytes
  parameters  Json?        // Filter parameters used for this report
  
  error       String?      // If failed
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenantId    String?
  tenant      Tenant? @relation(fields: [tenantId], references: [id])
}

// ==========================================
// SYSTEM LOGS MODULE (Unified Log Viewer)
// ==========================================

enum SystemLogCategory {
  LOG_CONSENT
  LOG_RIGHTS
  LOG_SECURITY
  LOG_SYSTEM
  LOG_AUDIT
  LOG_COMPLIANCE
}

model SystemLog {
  id        String            @id @default(uuid())
  category  SystemLogCategory
  action    String
  userName  String?
  target    String?           // Entity affected
  ipAddress String?
  details   Json?

  tenantId String?

  createdAt DateTime @default(now())
}

// ==========================================
// DASHBOARD WIDGET CONFIG (Per-User)
// ==========================================

model DashboardWidgetConfig {
  id      String @id @default(uuid())
  userId  String @unique // One config per user
  widgets Json   // Array of widget settings: {id, type, title, enabled, order, size, roles}

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// SYSTEM CONFIG (Usage Traceability — flow spec 3.8)
// ==========================================

model SystemConfig {
  id              String @id @default(uuid())
  name            String
  type            String    // e.g., "CRM", "HRMS", "ERP"
  integrationMode String   // e.g., "API", "SDK", "Webhook"
  authMethod      String   // e.g., "OAuth2", "API Key", "JWT"
  endpoint        String
  description     String?

  tenantId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// CONSENT WIDGET CONFIGURATION
// (Embeddable consent collection for third-party websites)
// ==========================================

enum WidgetDisplayMode {
  POPUP          // Modal popup on page load or trigger
  INLINE         // Embedded inside a div on the page
  SIDEBAR        // Slide-in sidebar panel
  BOTTOM_BAR     // Bottom bar (like cookie banner)
  FLOATING       // Floating button that expands
}

enum WidgetTrigger {
  PAGE_LOAD       // Show on page load
  BUTTON_CLICK    // Show when user clicks a button
  FORM_SUBMIT     // Intercept form submission
  MANUAL          // Show via JS API call only
  SCROLL          // Show after scrolling X%
}

enum WidgetStatus {
  WIDGET_ACTIVE
  WIDGET_DRAFT
  WIDGET_ARCHIVED
}

model ConsentWidgetConfig {
  id               String            @id @default(uuid())
  name             String            // e.g. "Registration Consent Form"

  // Linked Application & Consent Template
  applicationId    String
  application      Application       @relation(fields: [applicationId], references: [id])
  templateId       String
  template         ConsentTemplate   @relation(fields: [templateId], references: [id])

  // Display Settings
  displayMode      WidgetDisplayMode @default(POPUP)
  trigger          WidgetTrigger     @default(MANUAL)
  position         String            @default("center") // center, bottom-right, bottom-left, top

  // Branding
  themeColor       String            @default("#10b981")
  backgroundColor  String            @default("#ffffff")
  textColor        String            @default("#111827")
  buttonTextColor  String            @default("#ffffff")
  borderRadius     Int               @default(12)
  fontSize         Int               @default(14)
  logoUrl          String?

  // Content
  heading          String            @default("We value your privacy")
  description      String?           @db.Text

  // Consent Collection Fields
  collectName      Boolean           @default(false)
  collectEmail     Boolean           @default(true)
  collectPhone     Boolean           @default(false)
  requireAllPurposes Boolean         @default(false)  // If true, all purposes are mandatory
  showPrivacyLink  Boolean           @default(true)
  privacyPolicyUrl String?

  // Button Labels
  acceptAllText    String            @default("Accept All")
  rejectAllText    String            @default("Reject All")
  savePrefsText    String            @default("Save Preferences")

  // Multi-language
  defaultLanguage  String            @default("en")
  supportedLanguages String[]

  // Custom CSS override (advanced users)
  customCss        String?           @db.Text

  status           WidgetStatus      @default(WIDGET_DRAFT)

  // Tenant & Audit
  tenantId         String
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  createdBy        String

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([applicationId, status])
  @@index([tenantId])
}
