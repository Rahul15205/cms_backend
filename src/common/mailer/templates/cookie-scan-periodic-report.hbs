<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <style>
        body { font-family: 'Inter', sans-serif; line-height: 1.6; color: #334155; margin: 0; padding: 0; }
        .container { max-width: 600px; margin: 0 auto; padding: 40px 20px; background-color: #f8fafc; }
        .card { background: white; border-radius: 12px; padding: 32px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); border: 1px solid #e2e8f0; }
        .header { text-align: center; margin-bottom: 32px; }
        .title { font-size: 20px; font-weight: 700; color: #1e293b; margin: 0; }
        .footer { text-align: center; margin-top: 32px; font-size: 12px; color: #94a3b8; }
        .button { display: inline-block; padding: 12px 24px; background-color: #10b981; color: white; text-decoration: none; border-radius: 6px; font-weight: 600; margin-top: 24px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <img src="https://res.cloudinary.com/dlfzzfdx0/image/upload/v1777286182/Brand_title_with_tagline-removebg-preview_jpjpet.png" alt="Proteccio Data" style="width: 200px; height: auto; margin-bottom: 5px;">
            <p style="color:#2ecc71; margin:0; font-size:10px; letter-spacing:1px; font-weight: bold; text-transform: uppercase;">
                Data Privacy • Compliance • Implementation
            </p>
            <h1 class="title">Your Scheduled Website Compliance Report – {{websiteUrl}}</h1>
        </div>
        
        <div class="card">
            <p>Hi {{userName}},</p>
            <p>Your scheduled scan for <strong>{{websiteUrl}}</strong> has been completed. Here’s your latest compliance and risk summary:</p>
            
            <p><strong>Compliance Score:</strong> {{complianceScore}}%<br/>
            <strong>Previous:</strong> {{previousScore}}% | <strong>Change:</strong> {{scoreDifference}}%<br/>
            <strong>Risk Score:</strong> {{riskScore}} / 100 ({{riskLevel}})</p>

            <h3>Scan Summary</h3>
            <ul>
                <li><strong>Pages Scanned:</strong> {{totalPages}}</li>
                <li><strong>Scan Type:</strong> {{scanType}}</li>
                <li><strong>Scan Frequency:</strong> {{scanFrequency}}</li>
                <li><strong>Scan Date:</strong> {{scanDate}}</li>
            </ul>
            
            <h3>Cookie Insights</h3>
            <p><strong>Total Cookies Detected:</strong> {{cookieCount}}</p>
            <ul>
                <li>Necessary: {{necessaryCount}}</li>
                <li>Analytics: {{analyticsCount}}</li>
                <li>Marketing: {{marketingCount}}</li>
                <li>Functional: {{functionalCount}}</li>
                <li>Unknown: {{unknownCount}}</li>
            </ul>

            <h3>Third-Party Services Detected</h3>
            {{#if thirdPartyDomains.length}}
            <ul>
                {{#each thirdPartyDomains}}
                <li>{{this}}</li>
                {{/each}}
            </ul>
            {{else}}
            <p>None detected.</p>
            {{/if}}

            <h3>Compliance Overview (Latest)</h3>
            <ul style="list-style-type: none; padding-left: 0;">
                <li>{{bannerIcon}} Banner Installed: {{bannerText}}</li>
                <li>{{categorizationIcon}} Cookie Categorization: {{categorizationText}}</li>
                <li>{{loggingIcon}} Consent Logging: {{loggingText}}</li>
                <li>{{privacyIcon}} Privacy Policy: {{privacyText}}</li>
                <li>{{dsarIcon}} Data Access Request: {{dsarText}}</li>
                <li>{{httpsIcon}} HTTPS Security: {{httpsText}}</li>
                <li>{{thirdPartyIcon}} Third-party Disclosure: {{thirdPartyText}}</li>
                <li>{{optOutIcon}} Opt-out Mechanism: {{optOutText}}</li>
                <li>{{languageIcon}} Language Support: {{languageText}}</li>
                <li>{{grievanceIcon}} Grievance Mechanism: {{grievanceText}}</li>
            </ul>

            <h3>What Changed Since Last Scan</h3>
            {{#if changesDetected.length}}
            <ul>
                {{#each changesDetected}}
                <li>{{this}}</li>
                {{/each}}
            </ul>
            {{else}}
            <p>No significant changes detected.</p>
            {{/if}}

            <h3>Key Risks Identified</h3>
            {{#if keyRisks.length}}
            <ul>
                {{#each keyRisks}}
                <li>{{this}}</li>
                {{/each}}
            </ul>
            {{else}}
            <p>No major risks identified.</p>
            {{/if}}

            <h3>Recommended Actions</h3>
            {{#if recommendedActions.length}}
            <ul>
                {{#each recommendedActions}}
                <li>{{this}}</li>
                {{/each}}
            </ul>
            {{else}}
            <p>Continue to monitor your website compliance.</p>
            {{/if}}

            <h3>Next Steps</h3>
            <p>Are you excited to keep your website consistently compliant?</p>
            <ol>
                <li>Verify banner installation (if changes were made)</li>
                <li>Review and update banner customization</li>
                <li>Re-scan after implementing fixes</li>
                <li>Ensure continuous compliance monitoring</li>
            </ol>

            <div style="text-align: center;">
                <a href="{{dashboardUrl}}/cookies" class="button">View Dashboard</a>
            </div>
            
            <p style="margin-top:20px;">If you need assistance, our team is here to help.</p>
            <p>Best regards,<br/>Proteccio Data Team</p>
        </div>

        <div class="footer">
            <p>&copy; {{year}} Proteccio Data. All rights reserved.</p>
            <p>This is an automated notification from your Consent Management System.</p>
        </div>
    </div>
</body>
</html>
